<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IsGo - Control Panel & AI Dashboard</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --bg-dark: #0f172a;
            --bg-sidebar: #1e293b;
            --accent-purple: #6366f1;
            --accent-green: #10b981;
            --accent-red: #ef4444;
            --accent-blue: #3b82f6;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --border-color: #334155;
            --sidebar-width: 260px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        body { background-color: var(--bg-dark); color: var(--text-main); overflow-x: hidden; height: 100vh; }

        /* --- PANTALLA DE ACCESO --- */
        #auth-screen {
            display: flex; justify-content: center; align-items: center; height: 100vh; width: 100vw;
            position: fixed; top: 0; left: 0; background-color: var(--bg-dark); z-index: 9999;
        }
        .auth-card {
            background-color: var(--bg-sidebar); padding: 2.5rem; border-radius: 16px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.5); width: 90%; max-width: 400px; border: 1px solid var(--border-color); text-align: center;
        }
        .auth-logo { font-size: 2.5rem; font-weight: bold; margin-bottom: 0.5rem; display: flex; justify-content: center; align-items: center; gap: 10px; }
        .auth-logo i { color: var(--accent-purple); }
        .input-group { margin-bottom: 1.2rem; text-align: left; }
        .input-group label { display: block; color: var(--text-muted); margin-bottom: 0.5rem; font-size: 0.85rem; }
        .input-group input { width: 100%; padding: 0.75rem 1rem; background-color: var(--bg-dark); border: 1px solid var(--border-color); border-radius: 8px; color: white; outline: none; }
        .auth-btn { width: 100%; padding: 0.75rem; background-color: var(--accent-purple); color: white; border: none; border-radius: 8px; font-weight: bold; cursor: pointer; margin-top: 0.5rem; }
        .toggle-auth-btn { background: none; border: none; color: var(--accent-purple); cursor: pointer; font-weight: bold; margin-top: 1rem; font-size: 0.85rem; }

        /* --- NOTIFICACIONES FLASH IA (ESTILO TARJETA CON X) --- */
        #notification-zone { margin-bottom: 1.5rem; width: 100%; }
        .ai-notification {
            background: linear-gradient(135deg, #1e1b4b 0%, #2e2a78 100%);
            border-left: 4px solid var(--accent-purple); padding: 1.2rem; border-radius: 12px;
            margin-bottom: 0.75rem; display: flex; justify-content: space-between; align-items: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.25); border: 1px solid var(--border-color);
            animation: slideIn 0.3s ease;
        }
        .ai-notif-content { font-size: 0.9rem; line-height: 1.4; color: #f1f5f9; }
        .ai-notif-close { background: none; border: none; color: var(--text-muted); cursor: pointer; font-size: 1.2rem; transition: color 0.2s; padding-left: 1rem; }
        .ai-notif-close:hover { color: var(--accent-red); }

        /* --- ESTRUCTURA GENERAL --- */
        #app-container { display: none; flex-direction: column; height: 100vh; }
        .topbar { display: none; background-color: var(--bg-sidebar); padding: 1rem; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); position: fixed; top: 0; left: 0; right: 0; z-index: 100; }
        .sidebar { width: var(--sidebar-width); background-color: var(--bg-sidebar); height: 100%; position: fixed; top: 0; left: 0; border-right: 1px solid var(--border-color); display: flex; flex-direction: column; justify-content: space-between; padding: 1.5rem; z-index: 99; }
        .brand { font-size: 1.8rem; font-weight: bold; display: flex; align-items: center; gap: 10px; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); }
        .brand i { color: var(--accent-purple); }
        .menu-list { list-style: none; margin-top: 1.5rem; flex-grow: 1; }
        .menu-item { padding: 0.75rem 1rem; border-radius: 8px; margin-bottom: 0.4rem; cursor: pointer; display: flex; align-items: center; gap: 12px; color: var(--text-muted); transition: all 0.3s; }
        .menu-item:hover, .menu-item.active { background-color: rgba(99, 102, 241, 0.15); color: var(--text-main); }
        .menu-item.active i { color: var(--accent-purple); }
        
        .logout-btn { background: none; border: none; color: var(--accent-red); cursor: pointer; display: flex; align-items: center; gap: 8px; font-size: 0.85rem; padding: 0.5rem; width: 100%; justify-content: center; border-radius: 6px; border: 1px solid rgba(239, 68, 68, 0.2); margin-bottom: 1rem; transition: background 0.2s; }
        .logout-btn:hover { background: rgba(239, 68, 68, 0.1); }

        .user-footer { display: flex; align-items: center; gap: 12px; padding-top: 1rem; border-top: 1px solid var(--border-color); cursor: pointer; }
        .user-avatar { width: 40px; height: 40px; border-radius: 50%; background-color: var(--accent-purple); display: flex; justify-content: center; align-items: center; font-weight: bold; color: white; }
        .main-content { margin-left: var(--sidebar-width); padding: 2rem; flex-grow: 1; overflow-y: auto; }
        .view-section { display: none; }
        .view-section.active { display: block; }
        
        /* Modales, Tablas y Grids (Mantenidos de tu diseño original) */
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; margin-bottom: 2rem; }
        .stat-card { background-color: var(--bg-sidebar); padding: 1.5rem; border-radius: 12px; border: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center; }
        .stat-info h3 { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.5rem; text-transform: uppercase; }
        .stat-info p { font-size: 1.6rem; font-weight: bold; }
        .stat-icon { width: 44px; height: 44px; border-radius: 10px; display: flex; justify-content: center; align-items: center; font-size: 1.2rem; }
        .content-grid { display: grid; grid-template-columns: 1fr; gap: 2rem; }
        @media (min-width: 1024px) { .content-grid { grid-template-columns: 1fr 1.8fr; } }
        .card-panel { background-color: var(--bg-sidebar); padding: 1.5rem; border-radius: 12px; border: 1px solid var(--border-color); margin-bottom: 1.5rem; }
        .form-group { margin-bottom: 1rem; }
        .form-group label { display: block; font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.4rem; }
        .form-group input, .form-group select, .form-group textarea { width: 100%; padding: 0.65rem 0.8rem; background-color: var(--bg-dark); border: 1px solid var(--border-color); border-radius: 6px; color: white; outline: none; }
        .btn-action { width: 100%; padding: 0.7rem; background-color: var(--accent-purple); color: white; border: none; border-radius: 6px; font-weight: bold; cursor: pointer; }
        .table-responsive { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; text-align: left; }
        th, td { padding: 0.85rem 1rem; border-bottom: 1px solid var(--border-color); font-size: 0.9rem; }
        .badge { padding: 0.25rem 0.6rem; border-radius: 20px; font-size: 0.75rem; font-weight: bold; display: inline-block; }
        .badge-propuesta { background-color: rgba(234, 179, 8, 0.15); color: #eab308; }
        .badge-web { background-color: rgba(59, 130, 246, 0.15); color: #3b82f6; }
        .badge-activo { background-color: rgba(16, 185, 129, 0.15); color: #10b981; }
        .social-actions { display: flex; gap: 8px; }
        .btn-social { width: 32px; height: 32px; border-radius: 50%; display: flex; justify-content: center; align-items: center; text-decoration: none; color: white; font-size: 0.85rem; }
        .btn-wa { background-color: #25D366; }
        .btn-ig { background-color: #E1306C; }
        .btn-delete { background-color: rgba(239, 68, 68, 0.15); color: var(--accent-red); border: none; cursor: pointer; }
        
        @keyframes slideIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
        @media (max-width: 768px) {
            .topbar { display: flex; }
            .sidebar { transform: translateX(-100%); top: 60px; height: calc(100% - 60px); }
            .sidebar.open { transform: translateX(0); }
            .main-content { margin-left: 0; padding-top: 5rem; padding-left: 1rem; padding-right: 1rem; }
        }
    </style>
</head>
<body>

    <div id="auth-screen">
        <div class="auth-card" id="login-card">
            <div class="auth-logo"><i class="fa-solid fa-rocket"></i> IsGo</div>
            <p>Control Center Realtime</p>
            <form onsubmit="handleLogin(event)">
                <div class="input-group">
                    <label>Correo Electrónico</label>
                    <input type="email" id="login-email" value="isgoloyalty@gmail.com" required>
                </div>
                <div class="input-group">
                    <label>Contraseña</label>
                    <input type="password" id="login-password" placeholder="Ingresa tu contraseña" required>
                </div>
                <button type="submit" class="auth-btn">Iniciar Sesión</button>
            </form>
            <button class="toggle-auth-btn" onclick="toggleAuthMode(true)">¿No tienes cuenta? Regístrate aquí</button>
        </div>

        <div class="auth-card" id="register-card" style="display: none;">
            <div class="auth-logo"><i class="fa-solid fa-rocket"></i> Registrarse</div>
            <p>Crea tus credenciales de operador</p>
            <form onsubmit="handleRegister(event)">
                <div class="input-group">
                    <label>Nombre Completo</label>
                    <input type="text" id="reg-nombre" placeholder="Ej. Isaac IsGo" required>
                </div>
                <div class="input-group">
                    <label>Correo Electrónico</label>
                    <input type="email" id="reg-email" placeholder="correo@isgo.com" required>
                </div>
                <div class="input-group">
                    <label>Contraseña Maestra</label>
                    <input type="password" id="reg-password" placeholder="Crea tu clave de acceso" required>
                </div>
                <button type="submit" class="auth-btn" style="background-color: var(--accent-green);">Crear Cuenta</button>
            </form>
            <button class="toggle-auth-btn" onclick="toggleAuthMode(false)">¿Ya tienes cuenta? Inicia sesión</button>
        </div>
    </div>

    <div id="app-container">
        <div class="topbar">
            <div class="brand"><i class="fa-solid fa-rocket"></i> IsGo</div>
            <button class="menu-toggle" onclick="toggleSidebar()"><i class="fa-solid fa-bars"></i></button>
        </div>

        <div class="sidebar" id="sidebar">
            <div>
                <div class="brand"><i class="fa-solid fa-rocket"></i> IsGo</div>
                <ul class="menu-list">
                    <li class="menu-item active" onclick="switchView('dashboard')"><i class="fa-solid fa-chart-pie"></i> Dashboard</li>
                    <li class="menu-item" onclick="switchView('clientes')"><i class="fa-solid fa-users"></i> Clientes / CRM</li>
                    <li class="menu-item" onclick="switchView('consultor')"><i class="fa-solid fa-brain"></i> Asistente IA</li>
                    <li class="menu-item" onclick="switchView('finanzas')"><i class="fa-solid fa-wallet"></i> Finanzas</li>
                    <li class="menu-item" onclick="switchView('roi')"><i class="fa-solid fa-calculator"></i> Simulador ROI</li>
                </ul>
            </div>

            <div>
                <button class="logout-btn" onclick="handleLogout()"><i class="fa-solid fa-right-from-bracket"></i> Cerrar Sesión</button>
                <div class="user-footer" onclick="switchView('consultor')">
                    <div class="user-avatar" id="user-side-placeholder">I</div>
                    <div>
                        <h4 id="user-side-name">Isaac IsGo</h4>
                        <span style="font-size: 0.75rem; color: var(--text-muted);">Administrador Cloud</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="main-content">
            <div id="view-dashboard" class="view-section active">
                <div class="view-header">
                    <h1 id="dash-welcome">Bienvenido, Isaac</h1>
                    <p>Monitoreo estratégico global.</p>
                </div>
                
                <div id="notification-zone"></div>

                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-info"><h3>Leads Totales</h3><p id="dash-total-clientes">0</p></div>
                        <div class="stat-icon" style="background: rgba(99,102,241,0.1); color: var(--accent-purple);"><i class="fa-solid fa-user-group"></i></div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-info"><h3>Caja Comercial</h3><p id="dash-balance">$0.00</p></div>
                        <div class="stat-icon" id="dash-balance-icon" style="background: rgba(16,185,129,0.1); color: var(--accent-green);"><i class="fa-solid fa-scale-balanced"></i></div>
                    </div>
                </div>
            </div>

            <div id="view-clientes" class="view-section">
                <div class="view-header"><h1>CRM Base de Datos</h1><p>Control de estatus comerciales.</p></div>
                <div class="content-grid">
                    <div class="card-panel">
                        <h2>Registrar Prospecto</h2>
                        <form id="cliente-form" onsubmit="addCliente(event)">
                            <div class="form-group"><label>Nombre del Contacto</label><input type="text" id="c-nombre" required></div>
                            <div class="form-group"><label>Nombre del Negocio</label><input type="text" id="c-negocio" required></div>
                            <div class="form-group"><label>WhatsApp</label><input type="tel" id="c-whatsapp" required></div>
                            <div class="form-group"><label>Instagram (Sin @)</label><input type="text" id="c-insta"></div>
                            <div class="form-group">
                                <label>Estatus</label>
                                <select id="c-estatus">
                                    <option value="Propuesta">Solo Propuesta</option>
                                    <option value="Página Solicitada">Página Solicitada</option>
                                    <option value="Sistema Activo">Sistema Activo</option>
                                </select>
                            </div>
                            <div class="form-group"><label>Bitácora</label><textarea id="c-notes" rows="2"></textarea></div>
                            <button type="submit" class="btn-action">Guardar Registro</button>
                        </form>
                    </div>
                    <div class="card-panel">
                        <h2>Leads Activos</h2>
                        <div class="table-responsive">
                            <table>
                                <thead><tr><th>Negocio</th><th>Estatus</th><th>Acciones</th><th></th></tr></thead>
                                <tbody id="tabla-clientes-body"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div id="view-consultor" class="view-section">
                <div class="view-header"><h1>Consultor Estratégico e Instagram IA</h1><p>Pregúntale a la IA y dispara alertas al panel principal.</p></div>
                <div class="card-panel" style="max-width: 600px; margin: 0 auto;">
                    <h2>Análisis de Canales Digitales</h2>
                    <p style="color:var(--text-muted); font-size:0.85rem; margin-bottom:1.2rem;">La IA necesita saber a qué cuenta auditar. Escribe tu usuario o el de un cliente:</p>
                    <div class="form-group">
                        <label>Ingresa la cuenta de Instagram (Sin @)</label>
                        <input type="text" id="ai-insta-target" placeholder="Ej: joyeria_isgo o laserplus">
                    </div>
                    <div class="form-group">
                        <label>¿Qué tipo de estrategia quieres disparar?</label>
                        <select id="ai-strategy-type">
                            <option value="engagement">🔥 Carrusel de Alto Engagement (Contenido Educativo)</option>
                            <option value="conversion">💰 Story de Conversión (Llamado a la Acción)</option>
                            <option value="fidelidad">💎 Oferta Local para Monedero de Lealtad</option>
                        </select>
                    </div>
                    <button class="btn-action" onclick="lanzarNotificacionIA()"><i class="fa-solid fa-bolt"></i> Enviar Alerta Flash al Dashboard</button>
                </div>
            </div>

            <div id="view-finanzas" class="view-section">
                <div class="view-header"><h1>Libro Contable</h1><p>Registro de flujos monetarios.</p></div>
                <div class="content-grid">
                    <div class="card-panel">
                        <h2>Nueva Transacción</h2>
                        <form onsubmit="addTransaccion(event)">
                            <div class="form-group">
                                <label>Tipo</label>
                                <select id="f-tipo"><option value="ingreso">Ingreso</option><option value="gasto">Gasto</option></select>
                            </div>
                            <div class="form-group"><label>Concepto</label><input type="text" id="f-concepto" required></div>
                            <div class="form-group"><label>Monto</label><input type="number" step="0.01" id="f-monto" required></div>
                            <button type="submit" class="btn-action">Guardar Flujo</button>
                        </form>
                    </div>
                    <div class="card-panel">
                        <h2>Movimientos</h2>
                        <div class="table-responsive">
                            <table>
                                <thead><tr><th>Concepto</th><th>Tipo</th><th>Monto</th><th></th></tr></thead>
                                <tbody id="tabla-finanzas-body"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div id="view-roi" class="view-section">
                <div class="view-header"><h1>Calculadora ROI</h1><p>Punto de equilibrio para el cliente.</p></div>
                <div class="card-panel" style="max-width: 500px; margin: 0 auto;">
                    <div class="form-group"><label>Inversión IsGo ($)</label><input type="number" id="roi-inversion" value="5000" oninput="calcularROI()"></div>
                    <div class="form-group"><label>Ganancia por Venta ($)</label><input type="number" id="roi-ganancia" value="250" oninput="calcularROI()"></div>
                    <div class="form-group"><label>Visitas Mensuales Esperadas</label><input type="number" id="roi-visitas" value="3" oninput="calcularROI()"></div>
                    <div style="background: var(--bg-dark); padding: 1.5rem; border-radius: 8px; text-align: center; margin-top: 1.5rem;">
                        <h3>Clientes Fieles Necesarios</h3>
                        <p id="roi-resultado-clientes" style="font-size: 2.5rem; color: var(--accent-green); font-weight: bold;">7</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Inicialización de la base de datos de usuarios segura en localStorage
        let usuariosDB = JSON.parse(localStorage.getItem('isgo_users_db'));
        if (!usuariosDB) {
            // Usuario administrador maestro por defecto en su primera carga
            usuariosDB = [{ email: "isgoloyalty@gmail.com", password: "IsGO0307", nombre: "Isaac IsGo" }];
            localStorage.setItem('isgo_users_db', JSON.stringify(usuariosDB));
        }

        let usuarioActivo = JSON.parse(localStorage.getItem('isgo_active_session')) || null;
        let clientes = JSON.parse(localStorage.getItem('isgo_clientes')) || [];
        let transacciones = JSON.parse(localStorage.getItem('isgo_transacciones')) || [];

        function toggleAuthMode(toRegister) {
            document.getElementById('login-card').style.display = toRegister ? 'none' : 'block';
            document.getElementById('register-card').style.display = toRegister ? 'block' : 'none';
        }

        function handleRegister(e) {
            e.preventDefault();
            const email = document.getElementById('reg-email').value.trim();
            const password = document.getElementById('reg-password').value;
            const nombre = document.getElementById('reg-nombre').value.trim();

            let DB = JSON.parse(localStorage.getItem('isgo_users_db')) || [];
            if (DB.some(u => u.email === email)) {
                alert('Este correo electrónico ya está registrado en el sistema.');
                return;
            }

            DB.push({ email, password, nombre });
            localStorage.setItem('isgo_users_db', JSON.stringify(DB));
            alert('¡Cuenta administradora creada! Ya puedes iniciar sesión.');
            e.target.reset();
            toggleAuthMode(false);
        }

        function handleLogin(e) {
            e.preventDefault();
            const email = document.getElementById('login-email').value.trim();
            const pass = document.getElementById('login-password').value;

            let DB = JSON.parse(localStorage.getItem('isgo_users_db')) || [];
            const user = DB.find(u => u.email === email && u.password === pass);

            if (user) {
                usuarioActivo = user;
                localStorage.setItem('isgo_active_session', JSON.stringify(usuarioActivo));
                document.getElementById('auth-screen').style.display = 'none';
                document.getElementById('app-container').style.display = 'flex';
                initAppValues();
            } else {
                alert('Credenciales incorrectas. Verifica tu correo o contraseña.');
            }
        }

        function handleLogout() {
            localStorage.removeItem('isgo_active_session');
            location.reload();
        }

        function initAppValues() {
            render();
            calcularROI();
        }

        function toggleSidebar() { document.getElementById('sidebar').classList.toggle('open'); }

        function switchView(view) {
            document.querySelectorAll('.view-section').forEach(v => v.classList.remove('active'));
            document.querySelectorAll('.menu-item').forEach(m => m.classList.remove('active'));
            document.getElementById(`view-${view}`).classList.add('active');
            document.getElementById('sidebar').classList.remove('open');
            if(event && event.currentTarget && event.currentTarget.classList.contains('menu-item')) {
                event.currentTarget.classList.add('active');
            }
        }

        // LÓGICA INTERACTIVA DEL ASISTENTE IA PARA GENERAR NOTIFICACIONES CON "X"
        function lanzarNotificacionIA() {
            const cuenta = document.getElementById('ai-insta-target').value.trim().replace('@', '');
            const estrategia = document.getElementById('ai-strategy-type').value;

            if(!cuenta) {
                alert('Por favor, escribe primero una cuenta de Instagram para procesar el análisis.');
                return;
            }

            let copiaIdea = "";
            if (estrategia === "engagement") {
                copiaIdea = `Sube un carrusel hoy mismo: <em>"¿Cansado de perder clientes? Las tarjetas físicas no funcionan."</em> Muestra en la segunda diapositiva tu sistema interactivo IsGo. ¡Generará conversación masiva en la zona!`;
            } else if (estrategia === "conversion") {
                copiaIdea = `Lanza una Story con gancho directo: <em>"Últimos 3 cupos para implementar el monedero digital inteligente este mes con descuento."</em> Pon enlace directo a tu WhatsApp de atención de IsGo.`;
            } else {
                copiaIdea = `Recomiéndale a tu cliente de lealtad lanzar una promo relámpago: Regalar 50 puntos acumulables a los primeros 30 usuarios que escaneen el código QR del negocio desde sus redes.`;
            }

            const notifZone = document.getElementById('notification-zone');
            const notifId = 'ai-card-' + Date.now();

            const tarjetaHTML = `
                <div class="ai-notification" id="${notifId}">
                    <div class="ai-notif-content">
                        <strong>🤖 IsGo AI • Alerta para @${cuenta}:</strong><br>
                        ${copiaIdea}
                    </div>
                    <button class="ai-notif-close" onclick="eliminarNotificacion('${notifId}')"><i class="fa-solid fa-xmark"></i></button>
                </div>
            `;

            notifZone.innerHTML = tarjetaHTML + notifZone.innerHTML;
            alert('¡Alerta estratégica enviada con éxito al Dashboard principal!');
            switchView('dashboard');
        }

        function eliminarNotificacion(id) {
            const elemento = document.getElementById(id);
            if(elemento) elemento.remove();
        }
        window.eliminarNotificacion = eliminarNotificacion;

        // ACCIONES CRM
        function addCliente(e) {
            e.preventDefault();
            clientes.push({
                id: Date.now(),
                nombre: document.getElementById('c-nombre').value,
                negocio: document.getElementById('c-negocio').value,
                whatsapp: document.getElementById('c-whatsapp').value,
                insta: document.getElementById('c-insta').value,
                estatus: document.getElementById('c-estatus').value,
                notas: document.getElementById('c-notes').value
            });
            document.getElementById('cliente-form').reset();
            localStorage.setItem('isgo_clientes', JSON.stringify(clientes));
            render();
        }

        function deleteCliente(id) {
            if(confirm('¿Borrar lead del CRM?')) {
                clientes = clientes.filter(c => c.id !== id);
                localStorage.setItem('isgo_clientes', JSON.stringify(clientes));
                render();
            }
        }

        // ACCIONES FINANZAS
        function addTransaccion(e) {
            e.preventDefault();
            transacciones.push({
                id: Date.now(),
                concepto: document.getElementById('f-concepto').value,
                tipo: document.getElementById('f-tipo').value,
                monto: parseFloat(document.getElementById('f-monto').value)
            });
            e.target.reset();
            localStorage.setItem('isgo_transacciones', JSON.stringify(transacciones));
            render();
        }

        function deleteTransaccion(id) {
            transacciones = transacciones.filter(t => t.id !== id);
            localStorage.setItem('isgo_transacciones', JSON.stringify(transacciones));
            render();
        }

        function calcularROI() {
            const inversion = parseFloat(document.getElementById('roi-inversion').value) || 0;
            const ganancia = parseFloat(document.getElementById('roi-ganancia').value) || 0;
            const visitas = parseFloat(document.getElementById('roi-visitas').value) || 1;
            if (ganancia <= 0 || visitas <= 0) return;
            document.getElementById('roi-resultado-clientes').innerText = Math.ceil(inversion / (ganancia * visitas));
        }

        // REDERIZADO DE COMPONENTES
        function render() {
            if (!usuarioActivo) return;

            document.getElementById('user-side-name').innerText = usuarioActivo.nombre;
            document.getElementById('dash-welcome').innerText = `Bienvenido, ${usuarioActivo.nombre.split(' ')[0]}`;
            document.getElementById('user-side-placeholder').innerText = usuarioActivo.nombre.charAt(0).toUpperCase();

            // Tabla CRM
            const tbodyC = document.getElementById('tabla-clientes-body');
            tbodyC.innerHTML = '';
            clientes.forEach(c => {
                let bCls = c.estatus === 'Sistema Activo' ? 'badge-activo' : (c.estatus === 'Página Solicitada' ? 'badge-web' : 'badge-propuesta');
                tbodyC.innerHTML += `<tr>
                    <td><strong>${c.negocio}</strong><br><small style="color:var(--text-muted);">${c.nombre}</small></td>
                    <td><span class="badge ${bCls}">${c.estatus}</span></td>
                    <td><div class="social-actions">
                        <a href="https://wa.me/52${c.whatsapp}" target="_blank" class="btn-social btn-wa"><i class="fa-brands fa-whatsapp"></i></a>
                        ${c.insta ? `<a href="https://instagram.com/${c.insta}" target="_blank" class="btn-social btn-ig"><i class="fa-brands fa-instagram"></i></a>`:''}
                    </div></td>
                    <td><button onclick="deleteCliente(${c.id})" class="btn-delete"><i class="fa-solid fa-trash"></i></button></td>
                </tr>`;
            });

            // Tabla Contable
            const tbodyF = document.getElementById('tabla-finanzas-body');
            tbodyF.innerHTML = '';
            let ingresos = 0, gastos = 0;
            transacciones.forEach(t => {
                if(t.tipo === 'ingreso') ingresos += t.monto; else gastos += t.monto;
                tbodyF.innerHTML += `<tr>
                    <td>${t.concepto}</td>
                    <td style="color:${t.tipo==='ingreso'?'var(--accent-green)':'var(--accent-red)'}">${t.tipo.toUpperCase()}</td>
                    <td>$${t.monto.toFixed(2)}</td>
                    <td><button onclick="deleteTransaccion(${t.id})" class="btn-delete"><i class="fa-solid fa-trash"></i></button></td>
                </tr>`;
            });

            let net = ingresos - gastos;
            document.getElementById('dash-total-clientes').innerText = clientes.length;
            document.getElementById('dash-balance').innerText = `$${net.toFixed(2)}`;
            document.getElementById('dash-balance').style.color = net >= 0 ? 'var(--accent-green)' : 'var(--accent-red)';
        }

        // Mantener sesión al recargar
        if (usuarioActivo) {
            document.getElementById('auth-screen').style.display = 'none';
            document.getElementById('app-container').style.display = 'flex';
            initAppValues();
        }
    </script>
</body>
</html>

